# LLM Provider: 'openai' or 'deepseek'
LLM_PROVIDER=openai

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# DeepSeek API Key (required if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=

# Model name (defaults to gpt-4o-mini for openai, deepseek-chat for deepseek)
LLM_MODEL=gpt-4o-mini

# Xiaomi MiMo ASR (speech-to-text via /api/stt)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
STT_MODEL=mimo-v2.5-asr
