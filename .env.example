# ---------- LLM (OpenAI-compatible) — 绘图 ----------
# 与语音 STT 独立配置，互不影响
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# 讯飞星辰示例（Coding Plan / 推理服务）：
# LLM_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
# LLM_API_KEY=你的套餐订阅页 API Key
# LLM_MODEL=astron-code-latest
# 或自部署推理模型（modelId 如 xopkimik26，须与 Base URL 对应）

# ---------- STT 语音转写（与 LLM 无关）----------
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
STT_MODEL=mimo-v2.5-asr
